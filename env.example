# ── Server ───────────────────────────────────────────
PORT=3000
ALLOWED_ORIGIN=https://yourwebsite.com   # or * for dev

# ── Gmail (recommended) ───────────────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate an App Password and paste it below
GMAIL_USER=gitanshbhange@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── OR use any custom SMTP provider ──────────────────
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASS=your_smtp_password

# ── Where to receive messages ────────────────────────
RECIPIENT_EMAIL=gitanshbhange@email.com

# ── Admin endpoint token ──────────────────────────────
# Protect GET /api/submissions with a secret token
ADMIN_TOKEN=change_this_to_a_long_random_string
